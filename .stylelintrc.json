{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": ["tailwind", "apply", "layer", "import", "custom-media", "keyframes"]
      }
    ],
    "function-no-unknown": [
      true,
      {
        "ignoreFunctions": ["hsl", "min", "max", "calc", "clamp", "var"]
      }
    ]
  },
  "ignoreFiles": [
    "**/*.css"
  ]
}
